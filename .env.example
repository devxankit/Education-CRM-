# School CRM - Environment Configuration Template
# Copy this file to .env and fill in the values

# Server Settings
PORT=3000
NODE_ENV=production

# Database Settings
# For Docker setup, use: mongodb://mongodb:27017/ERP-School
MONGODB_URL=mongodb://mongodb:27017/ERP-School

# Security (Change these to strong random strings)
JWT_SECRET=YOUR_SECURE_JWT_SECRET
JWT_REFRESH_ACESS_SECRET=YOUR_SECURE_JWT_REFRESH_ACCESS_SECRET
JWT_REFRESH_SECRET=YOUR_SECURE_JWT_REFRESH_SECRET
JWT_RESET_SECRET=YOUR_SECURE_JWT_RESET_SECRET

# Third Party Services
# Firebase (Base64 encoded JSON)
FIREBASE_CREDENTIALS=

# Email Settings
EMAIL_USER=
EMAIL_PASS=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL (Change if using a custom domain)
FRONTEND_URL=http://localhost:3000
